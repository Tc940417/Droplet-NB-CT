scglue.models.configure_dataset(rna, "NB", use_highly_variable=True,use_layer="counts",use_cell_type="cell_type",use_batch="batch")
scglue.models.configure_dataset(atac, "NB", use_highly_variable=True,use_batch="batch")
guidance_hvf = guidance.subgraph(chain(rna.var.query("highly_variable").index,atac.var.query("highly_variable").index)).copy()
glue = scglue.models.fit_SCGLUE({"rna": rna, "atac": atac}, guidance_hvf,fit_kws={"directory": "glue"})

dx = scglue.models.integration_consistency(glue, {"rna": rna, "atac": atac}, guidance_hvf)
dx

import matplotlib.pyplot as plt
_ = sns.lineplot(x="n_meta", y="consistency", data=dx).axhline(y=0.05, c="darkred", ls="--")
plt.show()

rna.obsm["X_glue"] = glue.encode_data("rna", rna)
atac.obsm["X_glue"] = glue.encode_data("atac", atac)

scglue.data.transfer_labels(ref=rna, query=atac,field="cell_type",use_rep="X_glue",key_added="cell_type")

feature_embeddings = glue.encode_graph(guidance_hvf)
feature_embeddings = pd.DataFrame(feature_embeddings, index=glue.vertices)
feature_embeddings.iloc[:5, :5]

rna.varm["X_glue"] = feature_embeddings.reindex(rna.var_names).to_numpy()
atac.varm["X_glue"] = feature_embeddings.reindex(atac.var_names).to_numpy()

combined = ad.concat([rna, atac])
sc.pp.neighbors(combined, use_rep="X_glue", metric="cosine")
sc.tl.umap(combined)
sc.pl.umap(combined, color=["cell_type", "domain"], wspace=0.65)

glue.save("/mnt/e/sn_CT/glue-result/Rice/H3K4me3/glue.dill")
rna.write("/mnt/e/sn_CT/glue-result/Rice/H3K4me3/Rice_rna.h5ad", compression="gzip")
