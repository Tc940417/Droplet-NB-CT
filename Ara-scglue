from itertools import chain
import anndata as ad
import itertools
import networkx as nx
import pandas as pd
import scanpy as sc
import scglue
import seaborn as sns
from matplotlib import rcParams
scglue.plot.set_publication_params()
rcParams["figure.figsize"] = (4, 4)

rna = ad.read_h5ad("/mnt/d/sn-CT_broadpeaks/merge_object/merge-ref/ara_no.h5ad")

atac = ad.read_h5ad("/mnt/d/sn-CT_broadpeaks/merge_object/filter_cell_RDS/snCT_Ara.h5ad")
rna.obs["domain"] = "snRNA"
atac.obs["domain"] = "snCT_H3K4me3"
rna.X, rna.X.data
rna.layers["counts"] = rna.X.copy()
sc.pp.highly_variable_genes(rna, n_top_genes=2000, flavor="seurat_v3")

atac.X, atac.X.data
rna.var.head()
scglue.data.get_gene_annotation(rna, gtf="/mnt/d/sn-CT/Araref/Arabidopsis_thaliana.TAIR10.gtf",gtf_by="gene_id")
rna.var.loc[:, ["chrom", "chromStart", "chromEnd"]].head()
atac.var_names[:5]
split = atac.var_names.str.split(r"[:-]")
atac.var["chrom"] = split.map(lambda x: x[0])
atac.var["chromStart"] = split.map(lambda x: x[1]).astype(int)
atac.var["chromEnd"] = split.map(lambda x: x[2]).astype(int)
atac.var.head()
guidance = scglue.genomics.rna_anchored_guidance_graph(rna, atac,gene_region="promoter")
guidance
scglue.graph.check_graph(guidance, [rna, atac])
atac.var.head()

scglue.models.configure_dataset(rna, "NB", use_highly_variable=True,use_layer="counts")
scglue.models.configure_dataset(atac, "NB", use_highly_variable=True)
guidance_hvf = guidance.subgraph(chain(rna.var.query("highly_variable").index,atac.var.query("highly_variable").index)).copy()
glue = scglue.models.fit_SCGLUE({"rna": rna, "atac": atac}, guidance_hvf,fit_kws={"directory": "glue"})

dx = scglue.models.integration_consistency(glue, {"rna": rna, "atac": atac}, guidance_hvf)
dx


_ = sns.lineplot(x="n_meta", y="consistency", data=dx).axhline(y=0.05, c="darkred", ls="--")

rna.obsm["X_glue"] = glue.encode_data("rna", rna)
atac.obsm["X_glue"] = glue.encode_data("atac", atac)

scglue.data.transfer_labels(ref=rna, query=atac,field="cell_type",use_rep="X_glue",key_added="predicted_cell_type")

feature_embeddings = glue.encode_graph(guidance_hvf)
feature_embeddings = pd.DataFrame(feature_embeddings, index=glue.vertices)
feature_embeddings.iloc[:5, :5]

rna.varm["X_glue"] = feature_embeddings.reindex(rna.var_names).to_numpy()
atac.varm["X_glue"] = feature_embeddings.reindex(atac.var_names).to_numpy()


glue.save("/mnt/e/sn_CT/glue-result/Ara/glue.dill")
rna.write("/mnt/e/sn_CT/glue-result/Ara/rna.h5ad", compression="gzip")
atac.write("/mnt/e/sn_CT/glue-result/Ara/snCT.h5ad", compression="gzip")
nx.write_graphml(guidance_hvf, "/mnt/e/sn_CT/glue-result/Ara/guidance-hvf.graphml.gz")



